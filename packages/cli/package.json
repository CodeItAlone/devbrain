{
  "name": "devbrain-cli",
  "version": "0.1.0",
  "description": "Offline-first CLI tool providing persistent, deterministic project memory for AI assistants.",
  "keywords": [
    "devbrain",
    "cli",
    "ai",
    "context",
    "memory",
    "offline"
  ],
  "homepage": "https://github.com/CodeItAlone/devbrain#readme",
  "bugs": {
    "url": "https://github.com/CodeItAlone/devbrain/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeItAlone/devbrain.git"
  },
  "license": "MIT",
  "author": "Subrato Kundu (https://github.com/CodeItAlone/devbrain)",
  "type": "module",
  "main": "./dist/bin.js",
  "types": "./dist/bin.d.ts",
  "bin": {
    "devbrain": "dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/bin.js",
      "types": "./dist/bin.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "prepack": "node ../../scripts/prepare-cli.js"
  },
  "dependencies": {
    "@devbrain/core": "^0.1.0",
    "@devbrain/shared": "^0.1.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "fast-glob": "^3.3.2",
    "fast-xml-parser": "^5.9.3",
    "simple-git": "^3.23.0"
  },
  "bundleDependencies": [
    "@devbrain/core",
    "@devbrain/shared"
  ],
  "publishConfig": {
    "access": "public"
  }
}
